@page "/savedquizzes"
@inject QuizService QuizService
@rendermode InteractiveServer

<h3>Saved Quizzes</h3>

@if (quizzes == null)
{
    <p>Loading...</p>
}
else if (!quizzes.Any())
{
    <p>No quizzes found. <a href="/quizbuilder">Build one!</a></p>
}
else
{
    @foreach (var quiz in quizzes)
    {
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@quiz.Name</h5>
                <a href="/freerun/@quiz.Id" class="btn btn-primary btn-sm">Retake</a>
            </div>
            <div class="card-body">
                <p class="text-muted small">Created: @quiz.CreatedAt.ToLocalTime().ToString("g") | Cards: @quiz.QuizCards.Count</p>
                
                <h6>Run History</h6>
                @if (quiz.QuizRuns.Any())
                {
                    <table class="table table-sm table-bordered mt-2">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Correct</th>
                                <th>Wrong</th>
                                <th>Skipped</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var run in quiz.QuizRuns.OrderByDescending(r => r.CompletedAt))
                            {
                                <tr>
                                    <td>@run.CompletedAt.ToLocalTime().ToString("g")</td>
                                    <td>@run.Correct</td>
                                    <td>@run.Wrong</td>
                                    <td>@run.Skipped</td>
                                    <td>@run.TotalCards</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted italic">No runs recorded yet.</p>
                }
            </div>
        </div>
    }
}

@code {
    private List<Quiz>? quizzes;

    protected override async Task OnInitializedAsync()
    {
        quizzes = await QuizService.GetQuizzesAsync();
    }
}
